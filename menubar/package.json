{
  "name": "rhythm-menubar",
  "version": "1.0.0",
  "description": "Rhythm menu bar widget",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "electron:dev": "wait-on tcp:5174 && electron .",
    "start": "npm run build && NODE_ENV=production electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "menubar": "^9.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.rhythm.menubar",
    "productName": "Rhythm",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  }
}
